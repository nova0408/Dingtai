<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:macro name="dof3_hand_module" params="prefix parent_link xyz:='0 0 0' rpy:='0 0 0' chain_name:='' color:='' urdf_source:=''">
    <link name="${prefix}base_link"/>
    <link name="${prefix}finger1"/>
    <link name="${prefix}finger2"/>
    <link name="${prefix}finger3"/>

    <joint name="${prefix}mount" type="fixed">
      <parent link="${parent_link}"/>
      <child link="${prefix}base_link"/>
      <origin xyz="${xyz}" rpy="${rpy}"/>
    </joint>

    <joint name="${prefix}finger_1" type="revolute">
      <parent link="${prefix}base_link"/>
      <child link="${prefix}finger1"/>
      <origin xyz="0.00 0.03 0" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit lower="-0.7853982" upper="0.7853982" effort="20" velocity="2"/>
    </joint>

    <joint name="${prefix}finger_2" type="revolute">
      <parent link="${prefix}base_link"/>
      <child link="${prefix}finger2"/>
      <origin xyz="0.00 0.00 0" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit lower="-0.7853982" upper="0.7853982" effort="20" velocity="2"/>
    </joint>

    <joint name="${prefix}finger_3" type="revolute">
      <parent link="${prefix}base_link"/>
      <child link="${prefix}finger3"/>
      <origin xyz="0.00 -0.03 0" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit lower="-0.7853982" upper="0.7853982" effort="20" velocity="2"/>
    </joint>
  </xacro:macro>
</robot>
