<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:macro name="right_hand_module" params="prefix parent_link xyz:='0 0 0' rpy:='0 0 0' chain_name:='' color:='' urdf_source:=''">
    <link name="${prefix}base_link"/>
    <link name="${prefix}thumb_base_link"/>
    <link name="${prefix}thumb_tip_link"/>
    <link name="${prefix}middle_base_link"/>
    <link name="${prefix}middle_tip_link"/>

    <joint name="${prefix}mount" type="fixed">
      <parent link="${parent_link}"/>
      <child link="${prefix}base_link"/>
      <origin xyz="${xyz}" rpy="${rpy}"/>
    </joint>

    <joint name="${prefix}thumb_yaw" type="revolute">
      <parent link="${prefix}base_link"/>
      <child link="${prefix}thumb_base_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit lower="-1.5708" upper="1.5708" effort="1" velocity="1"/>
    </joint>

    <joint name="${prefix}thumb_open" type="revolute">
      <parent link="${prefix}thumb_base_link"/>
      <child link="${prefix}thumb_tip_link"/>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="-0.8" upper="0.8" effort="1" velocity="1"/>
    </joint>

    <joint name="${prefix}middle_base_open" type="revolute">
      <parent link="${prefix}base_link"/>
      <child link="${prefix}middle_base_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="-0.8" upper="0.8" effort="1" velocity="1"/>
    </joint>

    <joint name="${prefix}middle_tip_open" type="revolute">
      <parent link="${prefix}middle_base_link"/>
      <child link="${prefix}middle_tip_link"/>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="-0.8" upper="0.8" effort="1" velocity="1"/>
    </joint>

    <link name="${prefix}base_link">
      <visual>
        <geometry>
          <box size="0.03 0.02 0.02"/>
        </geometry>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <material name="hand_color">
          <color rgba="${color} 1"/>
        </material>
      </visual>
      <collision>
        <geometry>
          <box size="0.03 0.02 0.02"/>
        </geometry>
        <origin xyz="0 0 0" rpy="0 0 0"/>
      </collision>
    </link>

    <link name="${prefix}thumb_base_link">
      <visual>
        <geometry>
          <cylinder length="0.03" radius="0.004"/>
        </geometry>
        <origin xyz="0 0 0.015" rpy="1.57079632679 0 0"/>
        <material name="hand_color">
          <color rgba="${color} 1"/>
        </material>
      </visual>
      <collision>
        <geometry>
          <cylinder length="0.03" radius="0.004"/>
        </geometry>
        <origin xyz="0 0 0.015" rpy="1.57079632679 0 0"/>
      </collision>
    </link>

    <link name="${prefix}thumb_tip_link">
      <visual>
        <geometry>
          <cylinder length="0.03" radius="0.004"/>
        </geometry>
        <origin xyz="0 0 0.015" rpy="1.57079632679 0 0"/>
        <material name="hand_color">
          <color rgba="${color} 1"/>
        </material>
      </visual>
      <collision>
        <geometry>
          <cylinder length="0.03" radius="0.004"/>
        </geometry>
        <origin xyz="0 0 0.015" rpy="1.57079632679 0 0"/>
      </collision>
    </link>

    <link name="${prefix}middle_base_link">
      <visual>
        <geometry>
          <cylinder length="0.03" radius="0.004"/>
        </geometry>
        <origin xyz="0 0 0.015" rpy="1.57079632679 0 0"/>
        <material name="hand_color">
          <color rgba="${color} 1"/>
        </material>
      </visual>
      <collision>
        <geometry>
          <cylinder length="0.03" radius="0.004"/>
        </geometry>
        <origin xyz="0 0 0.015" rpy="1.57079632679 0 0"/>
      </collision>
    </link>

    <link name="${prefix}middle_tip_link">
      <visual>
        <geometry>
          <cylinder length="0.03" radius="0.004"/>
        </geometry>
        <origin xyz="0 0 0.015" rpy="1.57079632679 0 0"/>
        <material name="hand_color">
          <color rgba="${color} 1"/>
        </material>
      </visual>
      <collision>
        <geometry>
          <cylinder length="0.03" radius="0.004"/>
        </geometry>
        <origin xyz="0 0 0.015" rpy="1.57079632679 0 0"/>
      </collision>
    </link>
  </xacro:macro>
</robot>
