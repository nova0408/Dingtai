<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="right_hand">
  <link name="right_base_link"/>
  <link name="right_thumb_base_link">
    <visual>
      <geometry>
        <cylinder length="0.03" radius="0.004"/>
      </geometry>
      <origin xyz="0 0 0.015" rpy="1.57079632679 0 0"/>
      <material name="hand_color">
        <color rgba="0.9568627451 0.6392156863 0.3803921569 1"/>
      </material>
    </visual>
  </link>
  <link name="right_thumb_tip_link">
    <visual>
      <geometry>
        <cylinder length="0.03" radius="0.004"/>
      </geometry>
      <origin xyz="0 0 0.015" rpy="1.57079632679 0 0"/>
      <material name="hand_color">
        <color rgba="0.9568627451 0.6392156863 0.3803921569 1"/>
      </material>
    </visual>
  </link>
  <link name="right_middle_base_link">
    <visual>
      <geometry>
        <cylinder length="0.03" radius="0.004"/>
      </geometry>
      <origin xyz="0 0 0.015" rpy="1.57079632679 0 0"/>
      <material name="hand_color">
        <color rgba="0.9568627451 0.6392156863 0.3803921569 1"/>
      </material>
    </visual>
  </link>
  <link name="right_middle_tip_link">
    <visual>
      <geometry>
        <cylinder length="0.03" radius="0.004"/>
      </geometry>
      <origin xyz="0 0 0.015" rpy="1.57079632679 0 0"/>
      <material name="hand_color">
        <color rgba="0.9568627451 0.6392156863 0.3803921569 1"/>
      </material>
    </visual>
  </link>

  <joint name="right_thumb_yaw" type="revolute">
    <parent link="right_base_link"/>
    <child link="right_thumb_base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.5708" upper="1.5708" effort="1" velocity="1"/>
  </joint>

  <joint name="right_thumb_open" type="revolute">
    <parent link="right_thumb_base_link"/>
    <child link="right_thumb_tip_link"/>
    <origin xyz="0 0 0.03" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.8" upper="0.8" effort="1" velocity="1"/>
  </joint>

  <joint name="right_middle_base_open" type="revolute">
    <parent link="right_base_link"/>
    <child link="right_middle_base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.8" upper="0.8" effort="1" velocity="1"/>
  </joint>

  <joint name="right_middle_tip_open" type="revolute">
    <parent link="right_middle_base_link"/>
    <child link="right_middle_tip_link"/>
    <origin xyz="0 0 0.03" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.8" upper="0.8" effort="1" velocity="1"/>
  </joint>
</robot>
