<?xml version="1.0"?>
<robot name="lift">
  <link name="base_link"/>
  <link name="pitch_frame"/>
  <link name="lift_center"/>
  <link name="left_mount_link"/>
  <link name="right_mount_link"/>
  <link name="left_tcp_link"/>
  <link name="right_tcp_link"/>

  <!-- 俯仰关节：安装高度 0.8m，举升与俯仰在同一关节位置 -->
  <joint name="lift_pitch" type="revolute">
    <parent link="base_link"/>
    <child link="pitch_frame"/>
    <origin xyz="0 0 0.8" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.3490659" upper="0.7853982" effort="120" velocity="1.2"/>
  </joint>

  <!-- 举升关节：与俯仰同位，沿Z举升0.5m，使高度范围覆盖0.8~1.3 -->
  <joint name="lift_z" type="prismatic">
    <parent link="pitch_frame"/>
    <child link="lift_center"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="0" upper="0.5" effort="120" velocity="0.3"/>
  </joint>

  <!-- Y形左右分叉：左右间距约0.6m -->
  <joint name="left_mount_fixed" type="fixed">
    <parent link="lift_center"/>
    <child link="left_mount_link"/>
    <origin xyz="0 0.3 0" rpy="0 0 0"/>
  </joint>

  <joint name="right_mount_fixed" type="fixed">
    <parent link="lift_center"/>
    <child link="right_mount_link"/>
    <origin xyz="0 -0.3 0" rpy="0 0 0"/>
  </joint>

  <!-- 左右安装 TCP 帧：用于外部装配链路（如左右机械臂） -->
  <joint name="left_tcp_fixed" type="fixed">
    <parent link="left_mount_link"/>
    <child link="left_tcp_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <joint name="right_tcp_fixed" type="fixed">
    <parent link="right_mount_link"/>
    <child link="right_tcp_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>
</robot>
