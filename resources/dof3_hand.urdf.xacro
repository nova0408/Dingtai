<?xml version="1.0"?>
<robot name="dof3_hand">
  <link name="base_link"/>
  <link name="finger1"/>
  <link name="finger2"/>
  <link name="finger3"/>

  <joint name="finger_1" type="revolute">
    <parent link="base_link"/>
    <child link="finger1"/>
    <origin xyz="0.00 0.03 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.7853982" upper="0.7853982" effort="20" velocity="2"/>
  </joint>
  <joint name="finger_2" type="revolute">
    <parent link="base_link"/>
    <child link="finger2"/>
    <origin xyz="0.00 0.00 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.7853982" upper="0.7853982" effort="20" velocity="2"/>
  </joint>
  <joint name="finger_3" type="revolute">
    <parent link="base_link"/>
    <child link="finger3"/>
    <origin xyz="0.00 -0.03 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.7853982" upper="0.7853982" effort="20" velocity="2"/>
  </joint>
</robot>
