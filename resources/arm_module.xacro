<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:macro name="arm_module" params="prefix parent_link xyz:='0 0 0' rpy:='0 0 0' chain_name:='' color:='' urdf_source:=''">
    <link name="${prefix}base_link"/>

    <joint name="${prefix}mount" type="fixed">
      <parent link="${parent_link}"/>
      <child link="${prefix}base_link"/>
      <origin xyz="${xyz}" rpy="${rpy}"/>
    </joint>

    <joint name="${prefix}j1" type="revolute">
      <parent link="${prefix}base_link"/>
      <child link="${prefix}link1"/>
      <origin xyz="0.04 0 0" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit lower="-2.9670597" upper="2.9670597" effort="100" velocity="2"/>
    </joint>
    <link name="${prefix}link1"/>

    <joint name="${prefix}j2" type="revolute">
      <parent link="${prefix}link1"/>
      <child link="${prefix}link2"/>
      <origin xyz="0.24 0 0" rpy="0 0 0"/>
      <axis xyz="1 0 0"/>
      <limit lower="-2.0943951" upper="2.0943951" effort="100" velocity="2"/>
    </joint>
    <link name="${prefix}link2"/>

    <joint name="${prefix}j3" type="revolute">
      <parent link="${prefix}link2"/>
      <child link="${prefix}link3"/>
      <origin xyz="0.18 0 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="-2.9670597" upper="2.9670597" effort="100" velocity="2"/>
    </joint>
    <link name="${prefix}link3"/>

    <joint name="${prefix}j4" type="revolute">
      <parent link="${prefix}link3"/>
      <child link="${prefix}link4"/>
      <origin xyz="0.10 0 0" rpy="0 0 0"/>
      <axis xyz="1 0 0"/>
      <limit lower="-3.2288591" upper="3.2288591" effort="100" velocity="2"/>
    </joint>
    <link name="${prefix}link4"/>

    <joint name="${prefix}j5" type="revolute">
      <parent link="${prefix}link4"/>
      <child link="${prefix}link5"/>
      <origin xyz="0.08 0 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="-2.0943951" upper="2.0943951" effort="100" velocity="2"/>
    </joint>
    <link name="${prefix}link5"/>

    <joint name="${prefix}j6" type="revolute">
      <parent link="${prefix}link5"/>
      <child link="${prefix}link6"/>
      <origin xyz="0.1 0 0" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit lower="-6.2831853" upper="6.2831853" effort="100" velocity="2"/>
    </joint>
    <link name="${prefix}link6"/>
  </xacro:macro>
</robot>
